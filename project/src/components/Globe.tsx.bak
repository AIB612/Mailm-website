'use client';

import { useRef, useState, Suspense } from 'react';
import { Canvas, useFrame, useLoader } from '@react-three/fiber';
import { OrbitControls, Sphere, Stars, Html } from '@react-three/drei';
import * as THREE from 'three';
import { cantonSubsidies, CantonSubsidy } from '@/lib/data/cantons';

function latLngToVector3(lat: number, lng: number, radius: number): THREE.Vector3 {
  const phi = (90 - lat) * (Math.PI / 180);
  const theta = (lng + 180) * (Math.PI / 180);
  return new THREE.Vector3(
    -(radius * Math.sin(phi) * Math.cos(theta)),
    radius * Math.cos(phi),
    radius * Math.sin(phi) * Math.sin(theta)
  );
}

// Pulsing ring
function PulseRing({ position }: { position: THREE.Vector3 }) {
  const ref = useRef<THREE.Mesh>(null);
  
  useFrame(({ clock }) => {
    if (ref.current) {
      const t = (clock.getElapsedTime() * 0.5) % 1;
      ref.current.scale.setScalar(1 + t * 4);
      (ref.current.material as THREE.MeshBasicMaterial).opacity = (1 - t) * 0.8;
    }
  });

  const normal = position.clone().normalize();
  const quaternion = new THREE.Quaternion().setFromUnitVectors(new THREE.Vector3(0, 0, 1), normal);

  return (
    <mesh ref={ref} position={position} quaternion={quaternion}>
      <ringGeometry args={[0.04, 0.06, 32]} />
      <meshBasicMaterial color="#00ff88" transparent side={THREE.DoubleSide} />
    </mesh>
  );
}

// Canton marker
function CantonMarker({ canton, onSelect }: { canton: CantonSubsidy; onSelect: (c: CantonSubsidy) => void }) {
  const position = latLngToVector3(canton.coordinates[0], canton.coordinates[1], 2.02);
  const [hovered, setHovered] = useState(false);
  
  const color = canton.isHomeMarket ? '#00ff88' : '#22c55e';
  const size = canton.isHomeMarket ? 0.08 : 0.04;

  return (
    <group>
      <mesh
        position={position}
        onPointerOver={(e) => { e.stopPropagation(); setHovered(true); document.body.style.cursor = 'pointer'; }}
        onPointerOut={() => { setHovered(false); document.body.style.cursor = 'auto'; }}
        onClick={(e) => { e.stopPropagation(); onSelect(canton); }}
      >
        <sphereGeometry args={[hovered ? size * 1.5 : size, 16, 16]} />
        <meshBasicMaterial color={color} />
      </mesh>

      {/* Glow */}
      <mesh position={position}>
        <sphereGeometry args={[size * 3, 16, 16]} />
        <meshBasicMaterial color={color} transparent opacity={hovered ? 0.4 : 0.15} />
      </mesh>

      {/* Pulse for Basel */}
      {canton.isHomeMarket && <PulseRing position={position} />}

      {/* Label on hover */}
      {hovered && (
        <Html position={[position.x * 1.1, position.y * 1.1 + 0.15, position.z * 1.1]} center>
          <div className="bg-black/80 text-white text-xs px-2 py-1 rounded whitespace-nowrap">
            {canton.name}
          </div>
        </Html>
      )}
    </group>
  );
}

// Arc between two points
function Arc({ start, end }: { start: THREE.Vector3; end: THREE.Vector3 }) {
  const ref = useRef<THREE.Line>(null);
  
  const curve = new THREE.QuadraticBezierCurve3(
    start,
    new THREE.Vector3().addVectors(start, end).multiplyScalar(0.5).normalize().multiplyScalar(2.5),
    end
  );
  const points = curve.getPoints(30);
  const geometry = new THREE.BufferGeometry().setFromPoints(points);

  useFrame(({ clock }) => {
    if (ref.current) {
      const mat = ref.current.material as THREE.LineDashedMaterial;
      mat.dashOffset = -clock.getElapsedTime() * 0.5;
    }
  });

  return (
    <line ref={ref} geometry={geometry}>
      <lineDashedMaterial color="#00ff88" transparent opacity={0.4} dashSize={0.1} gapSize={0.05} />
    </line>
  );
}

// Earth with texture
function Earth({ onSelectCanton }: { onSelectCanton: (canton: CantonSubsidy) => void }) {
  const earthRef = useRef<THREE.Group>(null);
  const texture = useLoader(THREE.TextureLoader, 'https://unpkg.com/three-globe/example/img/earth-night.jpg');

  useFrame(() => {
    if (earthRef.current) {
      earthRef.current.rotation.y += 0.0008;
    }
  });

  const basel = cantonSubsidies.find(c => c.isHomeMarket);
  const baselPos = basel ? latLngToVector3(basel.coordinates[0], basel.coordinates[1], 2.02) : null;

  return (
    <group ref={earthRef}>
      {/* Earth */}
      <Sphere args={[2, 64, 64]}>
        <meshStandardMaterial map={texture} roughness={0.8} metalness={0.1} />
      </Sphere>

      {/* Atmosphere */}
      <Sphere args={[2.08, 64, 64]}>
        <meshBasicMaterial color="#4da6ff" transparent opacity={0.1} side={THREE.BackSide} />
      </Sphere>
      <Sphere args={[2.2, 64, 64]}>
        <meshBasicMaterial color="#87ceeb" transparent opacity={0.05} side={THREE.BackSide} />
      </Sphere>

      {/* Arcs from Basel */}
      {baselPos && cantonSubsidies.filter(c => !c.isHomeMarket).map(canton => (
        <Arc 
          key={canton.id} 
          start={baselPos} 
          end={latLngToVector3(canton.coordinates[0], canton.coordinates[1], 2.02)} 
        />
      ))}

      {/* Canton markers */}
      {cantonSubsidies.map((canton) => (
        <CantonMarker key={canton.id} canton={canton} onSelect={onSelectCanton} />
      ))}
    </group>
  );
}

// Loading fallback
function Loader() {
  return (
    <Html center>
      <div className="flex flex-col items-center gap-2">
        <div className="w-12 h-12 border-2 border-green-500/30 border-t-green-500 rounded-full animate-spin" />
        <span className="text-green-500 text-sm">Loading Globe...</span>
      </div>
    </Html>
  );
}

export default function Globe({
  onSelectCanton,
}: {
  onSelectCanton: (canton: CantonSubsidy | null) => void;
}) {
  return (
    <div className="w-full h-full">
      <Canvas
        camera={{ position: [0, 1.5, 4.5], fov: 45 }}
        gl={{ antialias: true, alpha: false }}
      >
        <color attach="background" args={['#030308']} />
        <fog attach="fog" args={['#030308', 5, 15]} />

        <ambientLight intensity={0.5} />
        <directionalLight position={[5, 3, 5]} intensity={1} />
        <pointLight position={[-5, -3, -5]} intensity={0.3} color="#4da6ff" />

        <Stars radius={100} depth={50} count={3000} factor={4} saturation={0} fade speed={0.3} />

        <Suspense fallback={<Loader />}>
          <Earth onSelectCanton={onSelectCanton} />
        </Suspense>

        <OrbitControls
          enableZoom
          enablePan={false}
          minDistance={3}
          maxDistance={8}
          enableDamping
          dampingFactor={0.05}
        />
      </Canvas>
    </div>
  );
}
