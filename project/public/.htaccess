Options +Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Directory-style route fallback: /foo -> /foo/index.html when present
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.+?)/?$ /$1/index.html [L]

  # Keep root assets and static files reachable
  RewriteRule ^(assets|geo)/ - [L]
  RewriteRule ^(robots\.txt|sitemap\.xml|live-check\.txt|malim\.svg)$ - [L]

  # SPA fallback
  RewriteRule ^ index.html [L]
</IfModule>
